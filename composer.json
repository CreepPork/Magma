{
    "name": "creeppork/magma",
    "version": "4.0.0-alpha",
    "description": "Magma is a CLI tool for Arma 3 server mod managment that works both on Windows and Linux.",
    "keywords": [
        "windows",
        "linux",
        "cli",
        "updater",
        "arma",
        "arma3",
        "magma",
        "linuxgsm"
    ],
    "homepage": "https://github.com/CreepPork/Magma",
    "type": "project",
    "license": "GPL-3.0-only",
    "support": {
        "issues": "https://github.com/CreepPork/Magma/issues",
        "source": "https://github.com/CreepPork/Magma"
    },
    "authors": [
        {
            "name": "Ralfs Garkaklis",
            "email": "ralfs@garkaklis.com"
        }
    ],
    "require": {
        "php": "^8.0",
        "laravel-zero/framework": "^8.4"
    },
    "require-dev": {
        "mockery/mockery": "^1.4.2",
        "pestphp/pest": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "bin": [
        "magma"
    ]
}
